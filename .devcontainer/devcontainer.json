{
  "name": "HavenKey Concierge",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:1-20-bullseye",

  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  // 1. Install deps  2. Copy env example so the app can start
  "postCreateCommand": "npm install && [ ! -f .env.local ] && cp .env.example .env.local || true",

  // Auto-start dev server every time the Codespace is opened
  "postAttachCommand": {
    "dev-server": "npm run dev"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "ms-vscode.vscode-typescript-next",
        "eamodio.gitlens",
        "mikestead.dotenv",
        "christian-kohler.path-intellisense",
        "dsznajder.es7-react-js-snippets",
        "pkief.material-icon-theme",
        "github.github-vscode-theme",
        "visualstudioexptteam.vscodeintellicode"
      ],
      "settings": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true,
        "editor.tabSize": 2,
        "terminal.integrated.defaultProfile.linux": "bash",
        "files.eol": "\n"
      }
    }
  },

  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "HavenKey — Dev Server",
      "onAutoForward": "openBrowser",
      "protocol": "http"
    }
  },

  "remoteUser": "node"
}
